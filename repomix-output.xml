}

/* ==================== PREMIUM NATIVE TABLE LOADING OVERLAY ==================== */
.table-loading-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(15, 23, 42, 0.65); /* Sleek translucent slate-900 background */
    backdrop-filter: blur(8px); /* Smooth premium glassmorphism blur */
