    // ----------------------------------------------------------------
    // 2B: NULL ON DELETE — Xóa parent → child giữ lại, FK = null
    // ----------------------------------------------------------------

    public function test_deleting_passage_nullifies_question_passage_id(): void
    {
        $passageId = $this->createPassage('Sample passage');

        $qId = DB::table('questions')->insertGetId([
