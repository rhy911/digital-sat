    border-bottom: 2px dashed #333;
}

.dropdown-toggle {
    padding: 4px 8px;
    transition: all 0.1s ease;
}

.dropdown-toggle:hover {
    background-color: white;
}

.icon-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 0 5px;
    padding: 5px;
    font-size: 12px;
    transition: background-color 0.3s;
    cursor: pointer;
    border: 1px solid transparent;
    border-radius: 4px;
